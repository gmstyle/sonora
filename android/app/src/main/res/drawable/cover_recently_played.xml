<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Gradient background -->
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:startColor="#3949AB"
                android:endColor="#8E24AA"
                android:angle="315" />
        </shape>
    </item>
    <!-- Centered icon -->
    <item
        android:drawable="@drawable/ic_timer"
        android:width="48dp"
        android:height="48dp"
        android:gravity="center" />
</layer-list>
