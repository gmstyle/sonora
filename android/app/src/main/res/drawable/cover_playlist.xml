<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Gradient background -->
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:startColor="#6A1B9A"
                android:endColor="#00B0FF"
                android:angle="315" />
        </shape>
    </item>
    <!-- Centered icon -->
    <item
        android:drawable="@drawable/ic_playlist"
        android:width="24dp"
        android:height="24dp"
        android:gravity="center" />
</layer-list>
